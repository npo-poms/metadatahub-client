      "@id" : "http://metadatahub.bijnpo.nl/817cec1a-51e3-47d1-88ff-384c438fe65a",
      "@type" : "AlternativeContentDescription",
      "contentDescription" : "Een schilderij van Edgar Fernhout, zoon van Charley Toorop en kleinzoon van Jan Toorop, Japans aardewerk, een 17-eeuws schilderij van een monnik in gebed en sieraden van Niki de Saint Phalle.",
      "hasObjectType" : {
        "@id" : "http://metadatahub.bijnpo.nl/afc0a6bd-9554-4de3-8ae9-5e7db77432fd",
        "@type" : [ "Concept", "NamedIndividual" ],
        "definition" : "The short description of the work.",
        "inScheme" : {
