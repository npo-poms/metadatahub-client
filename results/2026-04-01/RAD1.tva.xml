         <ProgramInformation programId="crid://npo/rcrs/DEV/685a9612780458463f05f5f0">
            <BasicDescription>
               <Title type="main">Bureau Buitenland</Title>
               <Synopsis length="medium">In Bureau Buitenland hoor je internationaal nieuws, reportages en geopolitiek. Met achtergronden en opmerkelijke verhalen, van maandag tot en met vrijdag van 13.30 tot 14.00 uur.</Synopsis>
