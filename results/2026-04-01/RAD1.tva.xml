               </Genre>
               <CreditsList/>
            </BasicDescription>
         </ProgramInformation>
         <ProgramInformation programId="crid://npo/rcrs/DEV/685a968595fcf61529e5e296">
            <BasicDescription>
               <Title type="main">Dit is de Dag</Title>
               <Synopsis length="medium">Dit is de Dag is een stevig opiniërend programma van de EO met Tijs van den Brink. Op dinsdag en vrijdag hoor je Margje Fikse of Hans van der Steeg.</Synopsis>
